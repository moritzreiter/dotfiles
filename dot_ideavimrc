" Search settings
set ignorecase
set smartcase
set hlsearch
set incsearch

" Plugins
set surround
set matchit
set NERDTree

" Temporarily disable search highlights with <C-l>
nnoremap <silent> <C-l> :<C-u>nohlsearch<CR><C-l>

" Don't make annoying sounds
set visualbell
set noerrorbells

" Use smart join
set ideajoin

" Don't switch to select mode when refactoring
set idearefactormode=keep

" Sync marks with idea bookmarks
set ideamarks


" Mappings
" --------

let mapleader = " "

" Navigation
map <A-[> <Action>(PreviousTab)
map <A-]> <Action>(NextTab)
map <A-w> <Action>(CloseEditor)

" Execution
map <A-r>   <Action>(Run)
map <A-d>   <Action>(Debug)
map <S-A-r> <Action>(RunClass)
map <S-A-d> <Action>(DebugClass)

" Inspection and Debugging
map <Leader>i  <Action>(ShowHoverInfo)
map <Leader>q  <Action>(QuickImplementations)
map <Leader>e  <Action>(ShowErrorDescription)
map <Leader>b  <Action>(ToggleLineBreakpoint)
map <Leader>sw <Action>(EditorToggleShowWhitespaces)

" Coding
map <Leader>g <Action>(Generate)

" Refactoring
map <Leader>r   <Action>(RefactoringMenu)
map <Leader>rem <Action>(ExtractMethod)
map <Leader>ri  <Action>(Inline)
